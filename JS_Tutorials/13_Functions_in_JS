# 🎯 21. Advanced Patterns 🔥

---

## Memoization

```js
function memo(fn) {
  let cache = {};

  return function(x) {
    if(cache[x]) return cache[x];
    return cache[x] = fn(x);
  };
}
```

---

## Debouncing

```js
function debounce(fn, delay) {
  let timer;

  return function() {
    clearTimeout(timer);
    timer = setTimeout(fn, delay);
  };
}
```

---

## Throttling

```js
function throttle(fn, limit) {
  let flag = true;

  return function() {
    if(flag){
      fn();
      flag = false;
      setTimeout(() => flag = true, limit);
    }
  };
}
```

